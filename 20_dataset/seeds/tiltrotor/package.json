  "integration_decisions": [
    {
      "decision": "integrate fuselage spine with wing-root spar sockets",
      "expected_gain": "removes repeated wing-root alignment setup and improves visible datum control",
      "guardrail": "wing keys and spar sockets remain externally inspectable"
    },
    {
      "decision": "keep tilting nacelles as removable service pods",
      "expected_gain": "protects motor/ESC and tilt-axis service access",
      "guardrail": "nacelle can be removed without opening fuselage"
    },
    {
      "decision": "keep tilt linkage as a separate cartridge",
      "expected_gain": "allows servo horn and linkage adjustment demonstration",
      "guardrail": "linkage cartridge can be replaced and adjusted after wing installation"
    },
    {
      "decision": "integrate battery rail with visible cable guide and payload service label",
      "expected_gain": "reduces loose trays and improves CG demonstration",
      "guardrail": "battery dummy remains slide-in and CG positions remain visible"
    },
    {
      "decision": "keep V-tail and landing gear replaceable",
      "expected_gain": "fragile handled parts can be replaced without sacrificing main fuselage",
      "guardrail": "tail hinge and gear mounts attach from outside"
    }
  ],
