{
  "schema": "blueprint_engineering_criteria_index_v1",
  "purpose": "Engineering judgment layer for six curated Blueprint evolution seeds. Criteria are compact, source-grounded rules used by scorecards, loop feedback, and future self-tune exports.",
  "source_policy": {
    "allowed": [
      "public-domain or openly published government handbooks and reports",
      "official vendor/manufacturer design guides",
      "MIT OCW and other openly licensed course materials",
      "project-owned seed files under 20_dataset/seeds",
      "Wikipedia/SEBoK style references for vocabulary only"
    ],
    "not_allowed": [
      "pirated books",
      "shadow-library PDFs",
      "copyrighted textbook scans",
      "operational weapon, propulsion, medical certification, or flight qualification instructions"
    ]
  },
  "criteria_files": [
    "common_dfm.json",
    "geometry_grounding.json",
    "service_access.json",
    "datum_tolerance.json",
    "structural_sizing.json",
    "mrl05_readiness.json",
    "uav_wing.json",
    "tiltrotor.json",
    "cubesat.json",
    "robot_arm.json",
    "haptic_glove.json",
    "small_launch_vehicle_mock_boundary.json",
    "electronics_routing.json",
    "assembly_integration.json"
  ],
  "reference_taxonomies": [
    "connection_types.json"
  ],
  "source_manifest": "../sources/manifest.json",
  "subsystem_taxonomy": "subsystem_taxonomy.json",
  "design_pass_protocol": "design_pass_protocol.json",
  "curated_seeds": [
    "long_range_recon_wing",
    "tiltrotor",
    "cubesat",
    "small_launch_vehicle",
    "robot_arm",
    "haptic_glove"
  ]
}
