{
  "schema": "blueprint_reference_asset_sources_v1",
  "policy": {
    "default_mode": "dry_run",
    "download_only_when_explicit": true,
    "respect_robots_txt": true,
    "rate_limit_seconds": 1.0,
    "max_file_mb_default": 250,
    "quarantine_unknown_license": true
  },
  "allowed_extensions": [
    ".step",
    ".stp",
    ".iges",
    ".igs",
    ".stl",
    ".obj",
    ".3mf",
    ".fcstd",
    ".scad",
    ".vsp3",
    ".svg",
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".webp",
    ".pdf",
    ".json",
    ".jsonl",
    ".csv",
    ".txt",
    ".md"
  ],
  "sources": [
    {
      "id": "nasa_3d_resources",
      "label": "NASA 3D Resources",
      "kind": "official_public_repository",
      "base_url": "https://science.nasa.gov/3d-resources/",
      "seed_targets": ["cubesat", "small_launch_vehicle", "long_range_recon_wing"],
      "license_hint": "NASA/public-government material; verify each asset page before training use.",
      "crawl": {
        "enabled": true,
        "mode": "discover_links",
        "max_depth": 1,
        "include_url_regex": "(?i)(3d|model|cad|stl|step|obj|glb|gltf|spacecraft|satellite|aircraft|rocket|download|resource)",
        "exclude_url_regex": "(?i)(login|account|cart|checkout|favicon|apple-touch-icon|wp-content/plugins|theme|logo|sprite|icon-[0-9])"
      }
    },
    {
      "id": "openvsp",
      "label": "OpenVSP",
      "kind": "open_source_tool_and_examples",
      "base_url": "https://openvsp.org/",
      "seed_targets": ["long_range_recon_wing", "tiltrotor"],
      "license_hint": "OpenVSP is NASA open-source software; verify model/example license before training use.",
      "crawl": {
        "enabled": true,
        "mode": "discover_links",
        "max_depth": 1,
        "include_url_regex": "(?i)(vsp|hangar|airshow|example|download|\\.vsp3|\\.stl|\\.step|\\.iges|\\.obj)",
        "exclude_url_regex": "(?i)(login|forum|account|favicon|apple-touch-icon|logo|theme|sprite)"
      }
    },
    {
      "id": "abc_dataset",
      "label": "ABC Dataset",
      "kind": "research_dataset",
      "base_url": "https://deep-geometry.github.io/abc-dataset/",
      "seed_targets": ["robot_arm", "haptic_glove", "cubesat"],
      "license_hint": "Research CAD dataset; use only after reviewing dataset terms.",
      "crawl": {
        "enabled": false,
        "mode": "manual_download",
        "max_depth": 0
      }
    },
    {
      "id": "github_open_cad",
      "label": "GitHub Open CAD Repositories",
      "kind": "open_source_repository_seed",
      "base_url": "https://github.com/",
      "seed_targets": ["robot_arm", "haptic_glove", "long_range_recon_wing", "tiltrotor", "cubesat"],
      "license_hint": "Only ingest repositories with an explicit compatible license.",
      "crawl": {
        "enabled": false,
        "mode": "manual_repo_list",
        "max_depth": 0
      }
    },
    {
      "id": "mcad_openscad",
      "label": "OpenSCAD MCAD Library",
      "kind": "open_source_repository_seed",
      "base_url": "https://github.com/openscad/MCAD",
      "seed_targets": ["gearbox_reducer", "hydraulic_manifold", "cnc_axis_carriage"],
      "license_hint": "LGPL-2.1; parametric mechanical parts library. Reference grammar only until license review.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 1,
        "include_url_regex": "(?i)(bearing|gear|involute|motor|screw|stepper|pulley|nut|bolt|shaft|bushing|coupling).*\\.scad$",
        "exclude_url_regex": "(?i)(bitmap|lego|test|example|logo)"
      }
    },
    {
      "id": "nopscadlib",
      "label": "NopSCADlib Parametric Parts",
      "kind": "open_source_repository_seed",
      "base_url": "https://github.com/nophead/NopSCADlib",
      "seed_targets": ["battery_pack_module", "cnc_axis_carriage", "underwater_sealed_sensor_housing"],
      "license_hint": "GPL-3.0; detailed parametric hardware library. Reference grammar only until license review.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 2,
        "include_url_regex": "(?i)(battery|bearing|rail|stepper|motor|o_ring|seal|box|cable|connector|pcb|drag_chain|fuseholder).*\\.scad$",
        "exclude_url_regex": "(?i)(examples|stls|tests|all\\.scad)"
      }
    },
    {
      "id": "freecad_models",
      "label": "FreeCAD Example Models",
      "kind": "open_source_tool_and_examples",
      "base_url": "https://github.com/FreeCAD/FreeCAD-library",
      "seed_targets": ["centrifugal_pump", "gearbox_reducer", "inline_6_engine_gasoline", "inline_6_engine_diesel"],
      "license_hint": "CC-BY-3.0 / LGPL; FreeCAD community library. Verify per-file license before training use.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 2,
        "include_url_regex": "(?i)(pump|impeller|volute|gear|engine|piston|valve|manifold|bearing|coupling|flange).*\\.(step|stp|fcstd|stl)$",
        "exclude_url_regex": "(?i)(logo|icon|test|thumbnail)"
      }
    },
    {
      "id": "grabcad_community",
      "label": "GrabCAD Community Library",
      "kind": "community_model_repository",
      "base_url": "https://grabcad.com/library",
      "seed_targets": ["centrifugal_pump", "inline_6_engine_gasoline", "inline_6_engine_diesel", "liquid_cold_plate", "gearbox_reducer"],
      "license_hint": "Per-model CC/public domain; must verify each model's license individually. Manual download only.",
      "crawl": {
        "enabled": false,
        "mode": "manual_download",
        "max_depth": 0
      }
    },
    {
      "id": "openfoam_tutorials",
      "label": "OpenFOAM Tutorial Geometries",
      "kind": "open_source_tool_and_examples",
      "base_url": "https://github.com/OpenFOAM/OpenFOAM-dev",
      "seed_targets": ["centrifugal_pump", "liquid_cold_plate"],
      "license_hint": "GPL-3.0; CFD tutorial meshes/geometries. Reference boundary condition grammar only.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 2,
        "include_url_regex": "(?i)(pump|mixer|impeller|channel|heat|cold|plate).*\\.(stl|obj|step)$",
        "exclude_url_regex": "(?i)(test|doc|logo|icon)"
      }
    },
    {
      "id": "openrocket",
      "label": "OpenRocket Motor/Component Database",
      "kind": "open_source_tool_and_examples",
      "base_url": "https://github.com/openrocket/openrocket",
      "seed_targets": ["small_launch_vehicle", "liquid_rocket_engine_academic"],
      "license_hint": "GPL-3.0; rocket simulation software. Motor specs and component geometry for reference grammar.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 2,
        "include_url_regex": "(?i)(motor|engine|nozzle|thrust|chamber|component|preset).*\\.(csv|json|xml|stl|step|obj)$",
        "exclude_url_regex": "(?i)(test|doc|logo|icon|gradle|maven)"
      }
    },
    {
      "id": "caelinux_elmer_examples",
      "label": "Elmer FEM Tutorial Geometries",
      "kind": "open_source_tool_and_examples",
      "base_url": "https://github.com/ElmerCSC/elmerfem",
      "seed_targets": ["liquid_cold_plate", "battery_pack_module"],
      "license_hint": "GPL-2.0; FEM solver tutorial geometries. Boundary condition / mesh grammar reference.",
      "crawl": {
        "enabled": true,
        "mode": "github_repo",
        "max_depth": 2,
        "include_url_regex": "(?i)(heat|thermal|channel|plate|battery|convection).*\\.(stl|step|stp|geo|msh)$",
        "exclude_url_regex": "(?i)(test|doc|logo|icon)"
      }
    }
  ]
}
